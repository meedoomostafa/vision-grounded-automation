AI__Gemini__ApiKeys__0=your_first_gemini_api_key_here
AI__Gemini__ApiKeys__1=your_second_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Grounding mode: first | all | none
GROUNDING_MODE=first

# Launch strategy: cascade | template_only
LAUNCH_STRATEGY=cascade

# Split retries (API vs MLLM)
API_MAX_RETRIES=2
API_BACKOFF_BASE=1.5
MLLM_MAX_RETRIES=2
MLLM_BACKOFF_BASE=1.5

# Grounding fanout controls for speed
GROUNDING_CAPTURE_ATTEMPTS=1
DIRECT_FULLSCREEN_ATTEMPTS=1
TEMPLATE_MIN_SCORE=0.46

OUTPUT_FOLDER=tjm-project
DRY_RUN=false
VISUAL_DEBUG=false
LOG_LEVEL=INFO
MLLM_MIN_INTERVAL_SECONDS=12.5
WATCHER_ENABLED=true
FOCUS_DEBOUNCE_SECONDS=5.0
FOCUS_POLL_INTERVAL_SECONDS=0.2
